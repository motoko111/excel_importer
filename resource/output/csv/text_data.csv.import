[deps]

files=["res://resource/output/csv/text_data.jp.translation", "res://resource/output/csv/text_data.en.translation", "res://resource/output/csv/text_data.ko.translation", "res://resource/output/csv/text_data.zh_CN.translation", "res://resource/output/csv/text_data.zh_TW.translation"]

